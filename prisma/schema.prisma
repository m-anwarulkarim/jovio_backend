generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  EMPLOYEE
  CLIENT
}

enum OfferStatus {
  PENDING
  ACCEPTED
  REJECTED
  EXPIRED
  CANCELLED
}

enum ProjectStatus {
  NEW
  UNDER_REVIEW
  ASSIGNED
  IN_PROGRESS
  WAITING_FOR_CLIENT
  REVIEW
  COMPLETED
  ON_HOLD
  CANCELLED
}

enum MessageSenderType {
  CLIENT
  ADMIN
  EMPLOYEE
}

enum MessageType {
  TEXT
  ISSUE
  UPDATE
  FEEDBACK
  SYSTEM
}

enum AttachmentType {
  IMAGE
  FILE
  LINK
}

enum NotificationType {
  NEW_MESSAGE
  NEW_OFFER
  OFFER_ACCEPTED
  OFFER_REJECTED
  PROJECT_ASSIGNED
  PROJECT_STATUS_CHANGED
  PROJECT_UPDATE
}

model User {
  id             String    @id @default(cuid())
  name           String
  email          String?   @unique
  phone          String?   @unique
  password       String?
  role           UserRole  @default(CLIENT)

  bio            String?
  isActive       Boolean   @default(true)
  emailVerified  Boolean   @default(false)
  image          String?

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  clientOffers        Offer[]         @relation("ClientOffers")
  clientProjects      Project[]       @relation("ClientProjects")

  adminOffers         Offer[]         @relation("AdminOffers")
  assignedByProjects  Project[]       @relation("AssignedByAdminProjects")

  assignedProjects    Project[]       @relation("AssignedEmployeeProjects")
  projectUpdates      ProjectUpdate[]

  sentMessages        Message[]
  uploadedAttachments Attachment[]    @relation("UploadedByUser")
  notifications       Notification[]

  sessions            Session[]
  accounts            Account[]

  @@index([role])
  @@map("users")
}

model Offer {
  id            String       @id @default(cuid())
  offerId       String       @unique
  title         String
  description   String
  price         Decimal      @db.Decimal(10, 2)
  deliveryDays  Int
  revisions     Int?
  note          String?
  status        OfferStatus  @default(PENDING)
  expiresAt     DateTime?

  clientId      String
  adminId       String

  acceptedAt    DateTime?
  rejectedAt    DateTime?

  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  client        User         @relation("ClientOffers", fields: [clientId], references: [id])
  admin         User         @relation("AdminOffers", fields: [adminId], references: [id])
  project       Project?
  attachments   Attachment[]
  notifications Notification[]

  @@index([clientId])
  @@index([adminId])
  @@index([status])
  @@map("offers")
}

model Project {
  id                 String         @id @default(cuid())
  projectId          String         @unique
  title              String
  description        String
  serviceCategory    String
  budget             Decimal?       @db.Decimal(10, 2)
  deadline           DateTime?
  status             ProjectStatus  @default(NEW)

  clientId           String
  assignedEmployeeId String?
  assignedByAdminId  String?
  offerId            String?        @unique

  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  client             User           @relation("ClientProjects", fields: [clientId], references: [id])
  assignedEmployee   User?          @relation("AssignedEmployeeProjects", fields: [assignedEmployeeId], references: [id])
  assignedByAdmin    User?          @relation("AssignedByAdminProjects", fields: [assignedByAdminId], references: [id])

  offer              Offer?         @relation(fields: [offerId], references: [id])
  messages           Message[]
  updates            ProjectUpdate[]
  attachments        Attachment[]
  notifications      Notification[]

  @@index([clientId])
  @@index([assignedEmployeeId])
  @@index([assignedByAdminId])
  @@index([offerId])
  @@index([status])
  @@map("projects")
}

model ProjectUpdate {
  id          String         @id @default(cuid())
  projectId   String
  userId      String
  progress    Int?
  note        String
  issue       String?
  createdAt   DateTime       @default(now())

  project     Project        @relation(fields: [projectId], references: [id])
  user        User           @relation(fields: [userId], references: [id])
  attachments Attachment[]

  @@index([projectId])
  @@index([userId])
  @@map("project_updates")
}

model Message {
  id          String            @id @default(cuid())
  projectId   String?
  senderId    String
  senderType  MessageSenderType
  type        MessageType       @default(TEXT)
  text        String
  isRead      Boolean           @default(false)
  createdAt   DateTime          @default(now())

  project     Project?          @relation(fields: [projectId], references: [id])
  sender      User              @relation(fields: [senderId], references: [id])
  attachments Attachment[]

  @@index([projectId])
  @@index([senderId])
  @@index([isRead])
  @@map("messages")
}

model Attachment {
  id              String          @id @default(cuid())
  type            AttachmentType
  url             String
  uploadedById    String?
  createdAt       DateTime        @default(now())

  messageId       String?
  projectId       String?
  offerId         String?
  projectUpdateId String?

  message         Message?        @relation(fields: [messageId], references: [id])
  project         Project?        @relation(fields: [projectId], references: [id])
  offer           Offer?          @relation(fields: [offerId], references: [id])
  projectUpdate   ProjectUpdate?  @relation(fields: [projectUpdateId], references: [id])
  uploadedBy      User?           @relation("UploadedByUser", fields: [uploadedById], references: [id])

  @@index([uploadedById])
  @@index([messageId])
  @@index([projectId])
  @@index([offerId])
  @@index([projectUpdateId])
  @@map("attachments")
}

model Notification {
  id         String            @id @default(cuid())
  userId     String
  offerId    String?
  projectId  String?
  type       NotificationType
  title      String
  body       String?
  isRead     Boolean           @default(false)
  createdAt  DateTime          @default(now())

  user       User              @relation(fields: [userId], references: [id])
  offer      Offer?            @relation(fields: [offerId], references: [id])
  project    Project?          @relation(fields: [projectId], references: [id])

  @@index([userId])
  @@index([offerId])
  @@index([projectId])
  @@index([isRead])
  @@map("notifications")
}

model Session {
  id         String    @id
  expiresAt  DateTime
  token      String    @unique
  userId     String
  user       User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("session")
}

model Account {
  id         String    @id
  accountId  String
  providerId String
  userId     String
  user       User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("account")
}