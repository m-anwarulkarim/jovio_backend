
generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  EMPLOYEE
  CLIENT
}

enum OfferStatus {
  PENDING
  ACCEPTED
  REJECTED
  EXPIRED
  CANCELLED
}

enum ProjectStatus {
  NEW
  UNDER_REVIEW
  ASSIGNED
  IN_PROGRESS
  WAITING_FOR_CLIENT
  REVIEW
  COMPLETED
  ON_HOLD
  CANCELLED
}

enum MessageSenderType {
  CLIENT
  ADMIN
  EMPLOYEE
}

enum MessageType {
  TEXT
  ISSUE
  UPDATE
  FEEDBACK
  SYSTEM
}

enum MessageConversationType {
  ADMIN_CLIENT
  ADMIN_EMPLOYEE
  DIRECT
}

enum AttachmentType {
  IMAGE
  FILE
  LINK
}

enum PublicSenderType {
  VISITOR
  ADMIN
}

enum NotificationType {
  NEW_MESSAGE
  NEW_OFFER
  OFFER_ACCEPTED
  OFFER_REJECTED
  PROJECT_ASSIGNED
  PROJECT_STATUS_CHANGED
  PROJECT_UPDATE
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
  CANCELLED
}


model User {
  id       String   @id @default(cuid())
  name     String
  email    String?  @unique
  phone    String?  @unique
  password String?
  role     UserRole @default(CLIENT)

  bio           String?
  isActive      Boolean @default(true)
  emailVerified Boolean @default(false)
  image         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clientOffers   Offer[]   @relation("ClientOffers")
  clientProjects Project[] @relation("ClientProjects")

  adminOffers        Offer[]   @relation("AdminOffers")
  assignedByProjects Project[] @relation("AssignedByAdminProjects")

  assignedProjects    Project[]       @relation("AssignedEmployeeProjects")
  projectUpdates      ProjectUpdate[]

  sentMessages     Message[] @relation("SentMessages")

  receivedMessages Message[] @relation("ReceivedMessages")

  uploadedAttachments Attachment[]    @relation("UploadedByUser")

  notifications       Notification[]

  publicMessages      PublicMessage[] @relation("AdminPublicMessages")

  clientPayments Payment[] @relation("ClientPayments")

  sessions Session[]
  accounts Account[]

  stripeCustomerId String?

  @@index([role])
  @@map("users")
}



model Payment {
  id                String        @id @default(cuid())
  offerId           String
  projectId         String?
  clientId          String
  amount            Decimal       @db.Decimal(10, 2)
  currency          String        @default("usd")
  status            PaymentStatus @default(PENDING)
  stripeSessionId   String?       @unique
  stripePaymentId   String?       @unique
  paidAt            DateTime?
  refundedAt        DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  offer   Offer    @relation(fields: [offerId], references: [id])
  project Project? @relation(fields: [projectId], references: [id])
  client  User     @relation("ClientPayments", fields: [clientId], references: [id])

  @@index([offerId])
  @@index([projectId])
  @@index([clientId])
  @@index([status])
  @@index([stripeSessionId])
  @@map("payments")
}



model Offer {
  id           String      @id @default(cuid())
  offerId      String      @unique
  title        String
  description  String
  price        Decimal     @db.Decimal(10, 2)
  deliveryDays Int
  revisions    Int?
  note         String?
  status       OfferStatus @default(PENDING)
  expiresAt    DateTime?

  clientId String
  adminId  String

  acceptedAt DateTime?
  rejectedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client        User           @relation("ClientOffers", fields: [clientId], references: [id])
  admin         User           @relation("AdminOffers", fields: [adminId], references: [id])
  project       Project?
  attachments   Attachment[]
  notifications Notification[]

  payments Payment[]

  @@index([clientId])
  @@index([adminId])
  @@index([status])
  @@map("offers")
}


model Project {
  id              String        @id @default(cuid())
  projectId       String        @unique
  title           String
  description     String
  serviceCategory String
  budget          Decimal?      @db.Decimal(10, 2)
  deadline        DateTime?
  status          ProjectStatus @default(NEW)

  clientId           String
  assignedEmployeeId String?
  assignedByAdminId  String?
  offerId            String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client           User  @relation("ClientProjects", fields: [clientId], references: [id])
  assignedEmployee User? @relation("AssignedEmployeeProjects", fields: [assignedEmployeeId], references: [id])
  assignedByAdmin  User? @relation("AssignedByAdminProjects", fields: [assignedByAdminId], references: [id])

  offer         Offer?          @relation(fields: [offerId], references: [id])
  messages      Message[]
  updates       ProjectUpdate[]
  attachments   Attachment[]
  notifications Notification[]
  payments Payment[]

  @@index([clientId])
  @@index([assignedEmployeeId])
  @@index([assignedByAdminId])
  @@index([offerId])
  @@index([status])
  @@map("projects")
}


model ProjectUpdate {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  progress  Int?
  note      String
  issue     String?
  createdAt DateTime @default(now())

  project     Project      @relation(fields: [projectId], references: [id])
  user        User         @relation(fields: [userId], references: [id])
  attachments Attachment[]

  @@index([projectId])
  @@index([userId])
  @@map("project_updates")
}


model Message {
  id               String                  @id @default(cuid())
  projectId        String? // optional করো
  senderId         String
  receiverId       String? // নতুন field
  senderType       MessageSenderType
  conversationType MessageConversationType
  type             MessageType             @default(TEXT)
  text             String
  isRead           Boolean                 @default(false)
  createdAt        DateTime                @default(now())

  project     Project?     @relation(fields: [projectId], references: [id]) // optional করো
  sender   User  @relation("SentMessages", fields: [senderId], references: [id])
  receiver User? @relation("ReceivedMessages", fields: [receiverId], references: [id])
  attachments Attachment[]

  // নতুন index
  @@index([projectId])
  @@index([senderId])
  @@index([receiverId])
  @@index([isRead])
  @@index([conversationType])
  @@index([projectId, conversationType])
  @@map("messages")
}


model PublicMessage {
  id         String           @id @default(cuid())
  visitorId  String
  adminId    String?
  senderType PublicSenderType
  text       String
  ipAddress  String?
  isRead     Boolean          @default(false)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  admin User? @relation("AdminPublicMessages", fields: [adminId], references: [id])

  @@index([visitorId])
  @@index([adminId])
  @@index([isRead])
  @@map("public_messages")
}


model Attachment {
  id           String         @id @default(cuid())
  type         AttachmentType
  url          String
  publicId     String?
  originalName String?
  mimeType     String?
  size         Int?
  uploadedById String?
  createdAt    DateTime       @default(now())

  messageId       String?
  projectId       String?
  offerId         String?
  projectUpdateId String?

  message       Message?       @relation(fields: [messageId], references: [id])
  project       Project?       @relation(fields: [projectId], references: [id])
  offer         Offer?         @relation(fields: [offerId], references: [id])
  projectUpdate ProjectUpdate? @relation(fields: [projectUpdateId], references: [id])
  uploadedBy    User?          @relation("UploadedByUser", fields: [uploadedById], references: [id])

  @@index([messageId])
  @@index([projectId])
  @@index([offerId])
  @@index([projectUpdateId])
  @@index([uploadedById])
  @@map("attachments")
}


model Notification {
  id        String           @id @default(cuid())
  userId    String
  offerId   String?
  projectId String?
  type      NotificationType
  title     String
  body      String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user    User     @relation(fields: [userId], references: [id])
  offer   Offer?   @relation(fields: [offerId], references: [id])
  project Project? @relation(fields: [projectId], references: [id])

  @@index([userId])
  @@index([offerId])
  @@index([projectId])
  @@index([isRead])
  @@map("notifications")
}


model Service {
  id              String   @id @default(cuid())
  slug            String   @unique
  title           String
  description     String
  longDescription String?
  icon            String?
  image           String?
  tag             String?
  projects        String?
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  features     ServiceFeature[]
  relatedPosts ServiceRelatedPost[]
  packages     ServicePackage[]
  featuredItems FeaturedItem[]

  @@index([slug])
  @@index([isActive])
  @@map("services")
}


model ServiceFeature {
  id        String @id @default(cuid())
  serviceId String
  text      String
  sortOrder Int    @default(0)

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([serviceId])
  @@map("service_features")
}


model ServicePackage {
  id           String  @id @default(cuid())
  serviceId    String
  name         String
  price        Decimal @db.Decimal(10, 2)
  description  String
  deliveryDays Int
  revisions    Int
  sortOrder    Int     @default(0)

  service  Service          @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  features PackageFeature[]

  @@index([serviceId])
  @@map("service_packages")
}


model PackageFeature {
  id        String @id @default(cuid())
  packageId String
  text      String
  sortOrder Int    @default(0)

  package ServicePackage @relation(fields: [packageId], references: [id], onDelete: Cascade)

  @@index([packageId])
  @@map("package_features")
}


model ServiceRelatedPost {
  id          String @id @default(cuid())
  serviceId   String
  title       String
  description String
  category    String
  image       String
  href        String
  sortOrder   Int    @default(0)

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([serviceId])
  @@map("service_related_posts")
}


model FeaturedItem {
  id               String   @id @default(cuid())
  slug             String   @unique
  serviceId        String?
  title            String
  shortDescription String
  description      String
  longDescription  String?  @db.Text
  category         String
  image            String
  overview         String   @db.Text
  challenge        String   @db.Text
  solution         String   @db.Text
  result           String   @db.Text
  rating           Float?
  reviews          Int?
  isActive         Boolean  @default(true)
  sortOrder        Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  service      Service?              @relation(fields: [serviceId], references: [id])
  features     FeaturedItemFeature[]
  technologies FeaturedItemTech[]
  packages     FeaturedItemPackage[]
  images       FeaturedItemImage[]

  @@index([serviceId])
  @@index([slug])
  @@index([isActive])
  @@map("featured_items")
}


model FeaturedItemFeature {
  id             String @id @default(cuid())
  featuredItemId String
  text           String
  sortOrder      Int    @default(0)

  featuredItem FeaturedItem @relation(fields: [featuredItemId], references: [id], onDelete: Cascade)

  @@index([featuredItemId])
  @@map("featured_item_features")
}


model FeaturedItemTech {
  id             String @id @default(cuid())
  featuredItemId String
  name           String

  featuredItem FeaturedItem @relation(fields: [featuredItemId], references: [id], onDelete: Cascade)

  @@index([featuredItemId])
  @@map("featured_item_techs")
}


model FeaturedItemPackage {
  id             String  @id @default(cuid())
  featuredItemId String
  name           String
  price          Decimal @db.Decimal(10, 2)
  description    String
  deliveryDays   Int
  revisions      Int
  sortOrder      Int     @default(0)

  featuredItem FeaturedItem               @relation(fields: [featuredItemId], references: [id], onDelete: Cascade)
  features     FeaturedItemPackageFeature[]

  @@index([featuredItemId])
  @@map("featured_item_packages")
}


model FeaturedItemPackageFeature {
  id        String @id @default(cuid())
  packageId String
  text      String
  sortOrder Int    @default(0)

  package FeaturedItemPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)

  @@index([packageId])
  @@map("featured_item_package_features")
}


model FeaturedItemImage {
  id             String @id @default(cuid())
  featuredItemId String
  url            String
  sortOrder      Int    @default(0)

  featuredItem FeaturedItem @relation(fields: [featuredItemId], references: [id], onDelete: Cascade)

  @@index([featuredItemId])
  @@map("featured_item_images")
}



model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?

  @@index([userId])
  @@map("session")
}


model Account {
  id         String @id
  accountId  String
  providerId String
  userId     String
  user       User   @relation(fields: [userId], references: [id])

  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
} 


model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}
